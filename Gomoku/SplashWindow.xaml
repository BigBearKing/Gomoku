<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gomoku.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="五子棋">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <!-- Centered content -->
        <Border x:Name="RootCard"
                CornerRadius="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Width="440"
                MinHeight="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="44,36">

            <StackPanel Spacing="14" HorizontalAlignment="Stretch">

                <!-- ====== Title Section ====== -->
                <TextBlock Text="五 子 棋"
                           FontSize="50"
                           FontWeight="ExtraLight"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           CharacterSpacing="100" />

                <TextBlock Text="G O M O K U"
                           FontSize="14"
                           FontWeight="Medium"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           CharacterSpacing="200"
                           Margin="0,-4,0,0" />

                <!-- Decorative stones -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="28"
                            Margin="0,10,0,6">
                    <!-- Black stone -->
                    <Grid>
                        <Ellipse Width="28" Height="28">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.35,0.35">
                                    <GradientStop Color="#FF505050" Offset="0"/>
                                    <GradientStop Color="#FF1E1E1E" Offset="0.6"/>
                                    <GradientStop Color="#FF050505" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                    <!-- White stone -->
                    <Grid>
                        <Ellipse Width="28" Height="28">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.35,0.35">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFE6E6E6" Offset="0.6"/>
                                    <GradientStop Color="#FFB4B4B4" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="28" Height="28"
                                 Stroke="#40000000"
                                 StrokeThickness="0.5" />
                    </Grid>
                </StackPanel>

                <!-- ====== Separator ====== -->
                <Rectangle Height="1"
                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                           Margin="0,4" />

                <!-- ====== Mode Selection ====== -->
                <TextBlock Text="选择游戏模式"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />

                <RadioButtons x:Name="ModeSelector"
                              SelectionChanged="ModeSelector_SelectionChanged">
                    <RadioButton Content="👤 双人对战"
                                 Tag="PvP"
                                 IsChecked="True" />
                    <RadioButton Content="🤖 人机对战"
                                 Tag="PvAI" />
                </RadioButtons>

                <!-- ====== Difficulty ====== -->
                <StackPanel x:Name="DifficultySection"
                            Visibility="Collapsed"
                            Spacing="8">
                    <TextBlock Text="AI 难度"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <ComboBox x:Name="DifficultyCombo"
                              SelectedIndex="2">
                        <ComboBoxItem Tag="Beginner">⭐ 入门 — 适合新手</ComboBoxItem>
                        <ComboBoxItem Tag="Easy">⭐⭐ 初级 — 基本策略</ComboBoxItem>
                        <ComboBoxItem Tag="Medium">⭐⭐⭐ 中级 — 中等挑战</ComboBoxItem>
                        <ComboBoxItem Tag="Hard">⭐⭐⭐⭐ 高级 — 需要技巧</ComboBoxItem>
                        <ComboBoxItem Tag="Master">⭐⭐⭐⭐⭐ 大师 — 极限挑战</ComboBoxItem>
                    </ComboBox>
                    <StackPanel x:Name="StarRow"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="3" />
                </StackPanel>

                <!-- ====== Separator ====== -->
                <Rectangle Height="1"
                           Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                           Margin="0,4" />

                <!-- ====== Start Button ====== -->
                <Button x:Name="StartButton"
                        Content="开 始 游 戏"
                        Style="{ThemeResource AccentButtonStyle}"
                        Height="46"
                        FontSize="17"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Stretch"
                        CornerRadius="8"
                        Click="StartButton_Click" />

                <!-- ====== Footer ====== -->
                <TextBlock Text="五子棋 · WinUI 3"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
